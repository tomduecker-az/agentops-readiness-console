# ============================================================
# AgentOps Readiness Console - Environment Template
# Copy this file to .env locally.
# Never commit real secrets.
# ============================================================

# Application
APP_ENV=development
APP_NAME=agentops-readiness-console
API_HOST=localhost
API_PORT=8000
WEB_PORT=3000

# OpenAI
OPENAI_API_KEY=

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# GitHub write-action integration
# Use a fine-grained token scoped only to the demo repo.
GITHUB_TOKEN=
GITHUB_OWNER=
GITHUB_REPO=

# Audit / policy settings
ENABLE_AUDIT_LOGGING=true
REQUIRE_HUMAN_APPROVAL_FOR_WRITES=true
